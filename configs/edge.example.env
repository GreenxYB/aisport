# Edge node configuration
ENV=dev
NODE_ID=1
COMMAND_POLL_INTERVAL_MS=500
CLOUD_API_BASE=http://localhost:8000
CAMERA_DEVICE=0
RTSP_URL=
SIMULATE_CAMERA=true
AUTO_START_CAPTURE=true
DISPLAY_PREVIEW=true
DISPLAY_START_LINE=true
DISPLAY_MIRROR=false
CAPTURE_FPS=15
CAPTURE_WIDTH=1280
CAPTURE_HEIGHT=640
MODEL_DIR=./data/models
SIMULATE_EVENTS=true
EVENT_INTERVAL_SEC=2.0
SIMULATE_FINISH_REPORTS=true
FINISH_INTERVAL_SEC=8.0
REPORT_ENABLED=false
REPORT_BASE_URL=http://localhost:8000/nodes/reports
REPORT_TIMEOUT_SEC=2.0
REPORT_RETRY_ENABLED=true
REPORT_RETRY_INTERVAL_SEC=3.0
REPORT_RETRY_MAX=5
ALGO_ENABLED=true
ALGO_TARGET_FPS=5
ALGO_LOG_PATH=logs/alg_events.jsonl
YOLO_BACKEND=pt
YOLO_ENGINE_PATH=yolo11n-pose-fp16.engine
YOLO_NAMES_PATH=pose.names
YOLO_PT_PATH=yolo11n-pose.pt
YOLO_CONF_THRES=0.6
YOLO_IOU_THRES=0.45
YOLO_IMGSZ=640
START_LINE_Y=480
FINISH_LINE_Y=520
KPS_CONF_THRES=0.5
TOE_PROXY_SCALE=0.45
# Unified visualization defaults (service preview + scripts), B,G,R
VIZ_LINE_COLOR=0,0,255
VIZ_READY_COLOR=0,255,0
VIZ_ALERT_COLOR=0,0,255
VIZ_COUNTDOWN_COLOR=0,255,255
VIZ_BOX_COLOR=0,255,0
VIZ_TOE_ANKLE_COLOR=255,0,0
VIZ_TOE_COLOR=0,255,255
VIZ_HUD_FONT_SCALE=1.0
VIZ_HUD_FONT_THICKNESS=2
VIZ_LINE_THICKNESS=2
VIZ_BOX_THICKNESS=1
VIZ_TOE_ANKLE_RADIUS=3
VIZ_TOE_RADIUS=4
VIZ_TOE_LINK_THICKNESS=1
# Start monitor script style defaults (B,G,R)
START_LINE_COLOR=0,0,255
START_READY_COLOR=0,255,0
START_ALERT_COLOR=0,0,255
START_COUNTDOWN_COLOR=0,255,255
START_BOX_COLOR=0,255,0
START_TOE_ANKLE_COLOR=255,0,0
START_TOE_COLOR=0,255,255
START_HUD_FONT_SCALE=1.0
START_HUD_FONT_THICKNESS=2
START_LINE_THICKNESS=2
START_BOX_THICKNESS=1
START_TOE_ANKLE_RADIUS=3
START_TOE_RADIUS=4
START_TOE_LINK_THICKNESS=1
# Finish line script style defaults (B,G,R)
FINISH_LINE_COLOR=255,0,255
FINISH_READY_COLOR=0,255,0
FINISH_RUNNING_COLOR=0,255,255
FINISH_TIMER_COLOR=0,255,255
FINISH_ID_COLOR=255,255,0
FINISH_RANK_COLOR=0,255,0
FINISH_TOE_ANKLE_COLOR=255,0,0
FINISH_TOE_COLOR=0,255,255
FINISH_HUD_FONT_SCALE=1.0
FINISH_HUD_FONT_THICKNESS=2
FINISH_ID_FONT_SCALE=0.6
FINISH_ID_FONT_THICKNESS=2
FINISH_RANK_FONT_SCALE=0.7
FINISH_RANK_FONT_THICKNESS=2
FINISH_LINE_THICKNESS=2
FINISH_TOE_ANKLE_RADIUS=3
FINISH_TOE_RADIUS=4
FINISH_TOE_LINK_THICKNESS=1
BAIDU_APP_ID=
BAIDU_API_KEY=
BAIDU_SECRET_KEY=
BAIDU_GROUP_ID=default
