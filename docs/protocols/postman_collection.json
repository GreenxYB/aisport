{
  "info": {
    "name": "AI Sport Cloud Workflow",
    "_postman_id": "8e2c6dc5-cloud-workflow",
    "description": "Mini-program to cloud workflow for smart track running projects.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "cloud_base_url",
      "value": "http://192.168.31.166:8000"
    },
    {
      "key": "session_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Create Session - 50m Start 1",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"project_type\": \"50m\",\n  \"start_node_id\": 1,\n  \"auto_start\": true,\n  \"binding_timeout_sec\": 15,\n  \"start_delay_ms\": 5000,\n  \"countdown_seconds\": 3,\n  \"race_timeout_sec\": 60\n}"
        },
        "url": {
          "raw": "{{cloud_base_url}}/sessions",
          "host": ["{{cloud_base_url}}"],
          "path": ["sessions"]
        }
      }
    },
    {
      "name": "Create Session - 100m Start 4",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"project_type\": \"100m\",\n  \"start_node_id\": 4,\n  \"auto_start\": true,\n  \"binding_timeout_sec\": 15,\n  \"start_delay_ms\": 5000,\n  \"countdown_seconds\": 3,\n  \"race_timeout_sec\": 80\n}"
        },
        "url": {
          "raw": "{{cloud_base_url}}/sessions",
          "host": ["{{cloud_base_url}}"],
          "path": ["sessions"]
        }
      }
    },
    {
      "name": "Create Session - 200m Start 7",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"project_type\": \"200m\",\n  \"start_node_id\": 7,\n  \"auto_start\": true,\n  \"binding_timeout_sec\": 20,\n  \"start_delay_ms\": 5000,\n  \"countdown_seconds\": 3,\n  \"race_timeout_sec\": 120\n}"
        },
        "url": {
          "raw": "{{cloud_base_url}}/sessions",
          "host": ["{{cloud_base_url}}"],
          "path": ["sessions"]
        }
      }
    },
    {
      "name": "List Sessions",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{cloud_base_url}}/sessions",
          "host": ["{{cloud_base_url}}"],
          "path": ["sessions"]
        }
      }
    },
    {
      "name": "Get Session",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{cloud_base_url}}/sessions/{{session_id}}",
          "host": ["{{cloud_base_url}}"],
          "path": ["sessions", "{{session_id}}"]
        }
      }
    },
    {
      "name": "Get Diagnostics",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{cloud_base_url}}/sessions/{{session_id}}/diagnostics",
          "host": ["{{cloud_base_url}}"],
          "path": ["sessions", "{{session_id}}", "diagnostics"]
        }
      }
    },
    {
      "name": "Get Results",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{cloud_base_url}}/sessions/{{session_id}}/results",
          "host": ["{{cloud_base_url}}"],
          "path": ["sessions", "{{session_id}}", "results"]
        }
      }
    },
    {
      "name": "List Online Nodes",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{cloud_base_url}}/nodes/online",
          "host": ["{{cloud_base_url}}"],
          "path": ["nodes", "online"]
        }
      }
    },
    {
      "name": "Manual Stop Session Nodes",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"cmd\": \"CMD_STOP\",\n  \"session_id\": \"{{session_id}}\",\n  \"node_id\": 1,\n  \"task_mode\": \"TRACK_RACE\",\n  \"config\": {\n    \"reason\": \"MANUAL_ABORT\"\n  }\n}"
        },
        "url": {
          "raw": "{{cloud_base_url}}/nodes/1/dispatch",
          "host": ["{{cloud_base_url}}"],
          "path": ["nodes", "1", "dispatch"]
        }
      }
    }
  ]
}
